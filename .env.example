# Browser-visible variables only. Anything prefixed with VITE_ is shipped to the client bundle.
# Never put private video AI provider secrets here; keep those on the server side.

VITE_VISUAL_MEDIA_CDN_BASE_URL=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
VITE_FRONTEND_FORGE_API_KEY=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# Opt-in local debug collector. Keep disabled for normal development and all public forks.
ENABLE_MANUS_DEBUG_COLLECTOR=false

# Docs translation (Chinese -> English markdown)
# Provider: openai | dashscope
DOCS_TRANSLATE_PROVIDER=
DOCS_TRANSLATE_MODEL=
DOCS_TRANSLATE_MAX_CHARS=6000
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
